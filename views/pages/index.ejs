<div id="auth-view" class="hero-section">
    <div class="container">
        <div class="row justify-content-center pt-5">
            <div class="col-md-5">
                <div class="glass-card p-5">
                    <h2 class="fw-bold mb-4 text-center">MagicRender</h2>
                    <ul class="nav nav-pills mb-4 justify-content-center">
                        <li class="nav-item"><a class="nav-link active" data-bs-toggle="pill" href="#tab-login">Login</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="pill" href="#tab-register">Register</a></li>
                    </ul>
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="tab-login">
                            <input type="email" id="login-email" class="form-control bg-dark border-0 text-white p-3 mb-3" placeholder="Email">
                            <input type="password" id="login-password" class="form-control bg-dark border-0 text-white p-3 mb-4" placeholder="Password">
                            <button onclick="Auth.login()" class="btn btn-premium w-100">Se connecter</button>
                        </div>
                        <div class="tab-pane fade" id="tab-register">
                            <input type="email" id="reg-email" class="form-control bg-dark border-0 text-white p-3 mb-3" placeholder="Email">
                            <input type="password" id="reg-password" class="form-control bg-dark border-0 text-white p-3 mb-4" placeholder="Password">
                            <button onclick="Auth.register()" class="btn btn-premium w-100">S'inscrire</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
