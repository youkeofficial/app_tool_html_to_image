<div class="d-flex h-100 w-100">
    <div class="content-wrapper flex-grow-1">
        <div id="result-toast-container" class="mb-4"></div>

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold m-0">Mes Vidéos</h4>
            <% if (magicEnabled) { %>
                <div class="input-group input-group-sm" style="max-width:380px;">
                    <input type="text" id="magic-prompt-video" class="form-control bg-dark text-white border-info border-opacity-25" placeholder="Sujet / Ambiance...">
                    <button onclick="Render.magicIdea('video')" class="btn btn-outline-info px-3">
                        <i class="bi bi-stars me-1"></i> Magic
                    </button>
                </div>
            <% } %>
        </div>

        <!-- Galerie vidéos en grille 2 colonnes -->
        <div class="row g-3" id="history-video"></div>
    </div>

    <!-- Sidebar : Editeur + Preview -->
    <div class="sidebar-history">
        <div class="glass-card p-3 border-info border-opacity-10">
            <h6 class="fw-bold mb-2 small text-uppercase text-info"><i class="bi bi-code-slash me-2"></i>HTML Animé Custom</h6>
            <textarea id="custom-html-video" class="form-control bg-dark text-white border-0 mb-2 small" rows="6" placeholder="<h1 style='animation: pulse 1s infinite;'>Titre</h1>"></textarea>

            <!-- Preview -->
            <div class="d-flex justify-content-between align-items-center mb-1">
                <small class="text-secondary">Aperçu Live</small>
                <button class="btn btn-link btn-sm text-info p-0" onclick="Render.refreshPreview('video')"><i class="bi bi-arrow-clockwise"></i></button>
            </div>
            <iframe id="preview-video" class="w-100 rounded border border-secondary mb-3" style="height: 200px; background:#000;" sandbox="allow-scripts allow-same-origin"></iframe>

            <div class="input-group input-group-sm mb-3">
                <span class="input-group-text bg-dark text-secondary border-0">Durée (sec)</span>
                <input type="number" id="custom-duration-video" class="form-control bg-dark text-white border-0" value="5" min="1" max="120">
            </div>
            <button onclick="Render.generateFromCustomHTML('video')" class="btn btn-premium w-100 btn-sm">
                <i class="bi bi-play-btn me-2"></i>Démarrer le Rendu
            </button>
        </div>
    </div>
</div>
